---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'audio-to-haptics',
  description = 'An npm library that converts audio into haptic feedback patterns synced to any audio or video element. Works on Android Chrome, Samsung Internet, and Opera Mobile.',
} = Astro.props;
const fullTitle = title === 'audio-to-haptics' ? title : `${title} — audio-to-haptics`;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

		<title>{fullTitle}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<!-- TODO: set og:url and og:image once deployed to Cloudflare Pages -->
		<!-- <meta property="og:url" content="https://YOUR_DOMAIN" /> -->
		<!-- <meta property="og:image" content="https://YOUR_DOMAIN/og.png" /> -->

		<!-- Twitter card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<!-- <meta name="twitter:image" content="https://YOUR_DOMAIN/og.png" /> -->
		<slot name="head" />
	</head>
	<body>
		<slot />
		<footer>
			<p class="footer-by">
				Built by
				<img src="https://github.com/AdityaAnuragi.png?size=32" class="avatar" alt="AdityaAnuragi" />
				Aditya Anuragi
			</p>
			<p class="footer-links">
				v0.0.1 &nbsp;·&nbsp; <a href="https://github.com/AdityaAnuragi/audio-to-haptics" target="_blank" rel="noopener noreferrer">GitHub</a> &nbsp;·&nbsp; <a href="https://www.linkedin.com/in/aditya-anuragi/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
			</p>
		</footer>
	</body>
</html>

<style is:global>
	*, *::before, *::after { box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		font-family: system-ui, -apple-system, sans-serif;
		color: #111;
	}
	/* H) Mesh gradient */
	body {
		background-color: #fafafa;
		background-image:
			radial-gradient(ellipse 60% 65% at 10% 18%,  rgba(194, 65,  12,  0.42) 0%, transparent 100%),
			radial-gradient(ellipse 60% 65% at 90% 25%,  rgba(29,  78,  216, 0.42) 0%, transparent 100%),
			radial-gradient(ellipse 55% 60% at 88% 80%,  rgba(194, 65,  12,  0.34) 0%, transparent 100%),
			radial-gradient(ellipse 55% 60% at 12% 82%,  rgba(29,  78,  216, 0.34) 0%, transparent 100%),
			radial-gradient(ellipse 65% 55% at 50% 50%,  rgba(109, 40,  217, 0.31) 0%, transparent 100%);
	}
	a { color: inherit; }
	pre, code { font-family: 'Cascadia Code', 'Fira Code', 'Courier New', monospace; }

	footer {
		border-top: 1px solid #eee;
		padding: 32px 24px;
		text-align: center;
		font-size: 0.9rem;
	}
	footer p { margin: 0 0 8px; }
	footer p:last-child { margin: 0; }
	footer a { color: #555; text-decoration: none; }
	footer a:hover { color: #111; }
	.footer-by {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		color: #444;
	}
	.avatar { width: 26px; height: 26px; border-radius: 50%; }
	.footer-links { color: #555; }
</style>
