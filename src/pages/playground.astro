---
import Layout from '../layouts/Layout.astro';
import PlaygroundComponent from '../components/Playground';
---

<Layout>

  <div class="topbar">
    <a href="/" class="back">← audio-to-haptics</a>
    <span class="badge">v0.0.1</span>
  </div>

  <div class="page">
    <h1>Playground</h1>
    <p class="sub">See how the algorithm detects haptic moments in audio. Adjust the sliders — the visualization updates in real time. On Android Chrome, you'll feel the difference too.</p>

    <PlaygroundComponent client:load />
  </div>

  <div class="cta-strip">
    <a href="/usage" class="btn-accent">View docs →</a>
  </div>


</Layout>

<style>
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .back {
    color: #555;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }
  .back:hover { color: #111; }
  .badge {
    font-size: 0.75rem;
    font-weight: 600;
    background: #f3f0ff;
    color: #7c3aed;
    border: 1px solid #ddd6fe;
    border-radius: 20px;
    padding: 3px 10px;
  }

  .page {
    max-width: 680px;
    margin: 0 auto;
    padding: 56px 24px 96px;
  }
  h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin: 0 0 12px;
    color: #0f0f0f;
  }
  .sub {
    font-size: 1rem;
    color: #555;
    margin: 0 0 48px;
    line-height: 1.6;
    max-width: 560px;
  }

  .cta-strip {
    padding: 48px 24px;
    text-align: center;
  }
  .btn-accent {
    text-decoration: none;
    padding: 13px 28px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    background: rgba(255,255,255,0.40);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.6);
    color: #111;
    display: inline-block;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-accent:hover { background: rgba(255,255,255,0.55); border-color: rgba(255,255,255,0.8); }
  .btn-accent:active { background: rgba(255,255,255,0.3); }

</style>
