---
import Layout from '../layouts/Layout.astro';
import CodeTabs from '../components/CodeTabs.astro';
import DiagramPipeline from '../components/DiagramPipeline.astro';
import DiagramSpike from '../components/DiagramSpike.astro';
import DiagramPWM from '../components/DiagramPWM.astro';
import {
  BASIC_REACT, BASIC_VANILLA,
  FILE_REACT, FILE_VANILLA,
  VIDEO_REACT, VIDEO_VANILLA,
  MUTE_REACT, MUTE_VANILLA,
  VISUAL_REACT, VISUAL_VANILLA,
  OPTS_REACT, OPTS_VANILLA,
} from '../data/snippets';
---

<Layout>

  <div class="topbar">
    <a href="/" class="back">← audio-to-haptics</a>
    <span class="badge">v0.0.1</span>
  </div>

  <div class="page">
    <h1>Usage</h1>

    <section class="block" id="install">
      <h2><a href="#install" class="anchor">Install</a></h2>
      <pre class="code-block"><code>npm install audio-to-haptics</code></pre>
    </section>

    <section class="block" id="quick-start">
      <h2><a href="#quick-start" class="anchor">Quick start</a></h2>
      <p class="section-desc">Analyze an audio or video file once — the library pre-computes when and how hard to vibrate. After that, just play the media and haptics fire automatically in sync, driven by a <code>requestAnimationFrame</code> loop.</p>
      <CodeTabs react={BASIC_REACT} vanilla={BASIC_VANILLA} />
    </section>

    <section class="block" id="examples">
      <h2><a href="#examples" class="anchor">Examples</a> <span class="examples-note">(snippets only — combine with the quick start above for full working code)</span></h2>

      <div class="recipe">
        <h3>URL or file input</h3>
        <p class="recipe-desc">Both paths use the same hook — <code>analyze()</code> takes a URL, <code>analyzeBuffer()</code> takes raw bytes from a file input or drag-and-drop.</p>
        <CodeTabs react={FILE_REACT} vanilla={FILE_VANILLA} />
      </div>

      <div class="recipe">
        <h3>Works with video too</h3>
        <p class="recipe-desc">Pass a <code>videoRef</code> instead of <code>audioRef</code> — the hook and engine attach to whichever media element you give them.</p>
        <CodeTabs react={VIDEO_REACT} vanilla={VIDEO_VANILLA} />
      </div>

      <div class="recipe">
        <h3>Mute and unmute</h3>
        <p class="recipe-desc">Suppress haptics without stopping playback or losing the analysis. One flag, instant toggle.</p>
        <CodeTabs react={MUTE_REACT} vanilla={MUTE_VANILLA} />
      </div>

      <div class="recipe">
        <h3>Drive a visual</h3>
        <p class="recipe-desc">The library exposes per-frame amplitude and chain type so you can sync any visual — SVG, canvas, CSS — to the same data driving the haptics. The visualiser on the <a href="/#examples">landing page</a> is built with exactly this.</p>
        <CodeTabs react={VISUAL_REACT} vanilla={VISUAL_VANILLA} />
      </div>

      <div class="recipe">
        <h3>Custom options</h3>
        <p class="recipe-desc">Tune how the algorithm detects haptic events. Try them live in the <a href="/playground">playground →</a></p>
        <CodeTabs react={OPTS_REACT} vanilla={OPTS_VANILLA} />
      </div>

    </section>

    <section class="block" id="how-it-works">
      <h2><a href="#how-it-works" class="anchor">How it works</a></h2>

      <div class="how-item">
        <DiagramPipeline />
        <p class="how-desc">Call <code>analyze()</code> once before playback. The library fetches and decodes the audio, splits it into ~60ms buckets, and pre-computes exactly when and how hard to vibrate. Nothing is recalculated during playback — it's all ready ahead of time.</p>
      </div>

      <div class="how-item">
        <DiagramSpike />
        <p class="how-desc">Each bucket is compared to the average of the buckets before it. If the current amplitude is significantly louder than the recent past, it triggers a vibration. This is edge detection — a kick drum stands out locally even inside a wall of loud music.</p>
      </div>

      <div class="how-item">
        <DiagramPWM />
        <p class="how-desc">Short chains (a kick, a gunshot, a heartbeat) fire as a single solid pulse — just impact. Longer chains use PWM: rapid on/off cycles where the duty cycle represents intensity. The motor's inertia smooths the pulses into a perceived partial amplitude.</p>
      </div>

    </section>

    <section class="block" id="browser-support">
      <h2><a href="#browser-support" class="anchor">Browser support</a></h2>
      <p class="support-note">Haptics require the <a href="https://developer.mozilla.org/en-US/docs/Web/API/Vibration_API" target="_blank" rel="noopener">Web Vibration API</a> — currently Android Chrome only. On desktop or iOS the library loads and analyzes normally, vibration calls are silently skipped.</p>
    </section>

  </div>

</Layout>

<style>
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    border-bottom: 1px solid #eee;
  }
  .back {
    color: #333;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }
  .back:hover { color: #111; }
  .badge {
    font-size: 0.75rem;
    font-weight: 600;
    background: #f3f0ff;
    color: #7c3aed;
    border: 1px solid #ddd6fe;
    border-radius: 20px;
    padding: 3px 10px;
  }

  .page {
    max-width: 680px;
    margin: 0 auto;
    padding: 56px 24px 96px;
  }
  h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin: 0 0 48px;
    color: #0f0f0f;
  }

  .block { margin-bottom: 48px; }
  .block + .block {
    border-top: 1px solid rgba(0,0,0,0.07);
    padding-top: 48px;
  }

  h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: #0f0f0f;
    margin: 0 0 16px;
  }
  .anchor {
    color: inherit;
    text-decoration: none;
  }
  .anchor:hover { text-decoration: underline; }
  .examples-note {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    color: #333;
  }

  .code-block {
    background: #0f0f0f;
    color: #e8e8e8;
    padding: 16px 20px;
    border-radius: 10px;
    font-size: 0.9rem;
    margin: 0;
  }

  .recipe {
    margin-bottom: 40px;
  }
  .recipe:last-child { margin-bottom: 0; }

  h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #0f0f0f;
    margin: 0 0 6px;
  }

  .section-desc {
    font-size: 0.875rem;
    color: #333;
    margin: 0 0 20px;
    line-height: 1.6;
  }
  .section-desc code {
    font-family: monospace;
    font-size: 0.85em;
    background: rgba(124, 58, 237, 0.08);
    color: #6d28d9;
    padding: 1px 5px;
    border-radius: 4px;
  }

  .recipe-desc {
    font-size: 0.875rem;
    color: #333;
    margin: 0 0 14px;
    line-height: 1.6;
  }
  .recipe-desc code {
    font-family: monospace;
    font-size: 0.85em;
    background: rgba(124, 58, 237, 0.08);
    color: #6d28d9;
    padding: 1px 5px;
    border-radius: 4px;
  }
  .recipe-desc a {
    color: #7c3aed;
    text-decoration: none;
    font-weight: 500;
  }
  .recipe-desc a:hover { text-decoration: underline; }

  .how-item { margin-bottom: 64px; }
  .how-item:last-child { margin-bottom: 0; }
  .how-desc {
    font-size: 0.875rem;
    color: #333;
    line-height: 1.6;
    margin: 14px 0 0;
  }
  .how-desc code {
    font-family: monospace;
    font-size: 0.85em;
    background: rgba(124, 58, 237, 0.08);
    color: #6d28d9;
    padding: 1px 5px;
    border-radius: 4px;
  }

  .support-note {
    font-size: 0.875rem;
    color: #333;
    line-height: 1.6;
    margin: 0;
  }
  .support-note a {
    color: #7c3aed;
    text-decoration: none;
    font-weight: 500;
  }
  .support-note a:hover { text-decoration: underline; }
</style>
