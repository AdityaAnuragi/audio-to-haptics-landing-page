---
import Layout from '../layouts/Layout.astro';
import UsageTabs from '../components/UsageTabs';
---

<Layout>
  <div class="page">

    <a href="/" class="back">← Home</a>

    <h1>Usage</h1>

    <h2>Install</h2>
    <pre class="code-block"><code>npm install audio-to-haptics</code></pre>

    <h2>API</h2>
    <UsageTabs client:load />

  </div>
</Layout>

<style>
  .page {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 24px 96px;
  }
  .back {
    display: inline-block;
    color: #aaa;
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 40px;
  }
  .back:hover { color: #111; }
  h1 { margin: 0 0 40px; font-size: 2rem; }
  h2 { margin: 0 0 12px; font-size: 1rem; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.05em; }
  h2 + * { margin-bottom: 40px; }
  .code-block {
    background: #111;
    color: #f8f8f8;
    padding: 16px 20px;
    border-radius: 8px;
    font-size: 0.9rem;
    margin: 0;
  }
</style>
