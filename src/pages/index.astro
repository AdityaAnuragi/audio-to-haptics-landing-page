---
import Layout from '../layouts/Layout.astro';
import VideoExample from '../components/VideoExample';
---

<Layout>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-icons">
      <!-- Waveform bars -->
      <svg xmlns="http://www.w3.org/2000/svg" width="52" height="32" viewBox="0 0 52 32" aria-hidden="true">
        <rect x="0"  y="14" width="6" height="4"  rx="3" fill="white" opacity="0.4"/>
        <rect x="8"  y="10" width="6" height="12" rx="3" fill="white" opacity="0.6"/>
        <rect x="16" y="3"  width="6" height="26" rx="3" fill="white"/>
        <rect x="24" y="7"  width="6" height="18" rx="3" fill="white" opacity="0.9"/>
        <rect x="32" y="11" width="6" height="10" rx="3" fill="white" opacity="0.6"/>
        <rect x="40" y="14" width="6" height="4"  rx="3" fill="white" opacity="0.4"/>
      </svg>
      <span class="hero-arrow">→</span>
      <!-- Phone with vibration lines -->
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="36" viewBox="-10 -2 48 40" aria-hidden="true" fill="none" stroke="white" stroke-linecap="round">
        <path d="M-6 11 Q-10 18 -6 25" stroke-width="1.5" opacity="0.35"/>
        <path d="M-2 13 Q-5 18 -2 23"  stroke-width="2"   opacity="0.6"/>
        <rect x="2" y="0" width="24" height="36" rx="4" stroke-width="2"/>
        <rect x="5" y="4" width="18" height="26" rx="2" fill="white" opacity="0.12" stroke="none"/>
        <path d="M30 13 Q33 18 30 23"  stroke-width="2"   opacity="0.6"/>
        <path d="M34 11 Q38 18 34 25" stroke-width="1.5" opacity="0.35"/>
      </svg>
    </div>

    <h1>INSERT CATCHY TAGLINE HERE</h1>
    <p>Sync vibration to any audio or video on Android Chrome — no native app required.</p>

    <div class="hero-ctas">
      <a href="#examples" class="btn-ghost">See it in action ↓</a>
      <a href="/usage" class="btn-solid">Get started →</a>
    </div>
  </section>

  <!-- DESKTOP WARNING BANNER -->
  <div class="banner" id="banner">
    <div class="banner-inner">
      <div class="banner-text">
        <p class="banner-title">⚠ Vibration only works on Android Chrome.</p>
        <p class="banner-sub">Not supported on iOS Safari, desktop browsers, or Firefox.</p>
      </div>
      <div class="banner-qr">
        <div class="qr-box">INSERT QR CODE HERE</div>
        <p class="qr-label">Scan on your Android phone</p>
      </div>
    </div>
  </div>
  <script>
    if ('vibrate' in navigator && /Android/i.test(navigator.userAgent)) {
      document.getElementById('banner')!.style.display = 'none';
    }
  </script>

  <!-- EXAMPLES -->
  <section class="examples" id="examples">
    <h2>Hear it. Feel it.</h2>
    <p class="examples-sub">Play on Android Chrome and feel your phone vibrate in sync.</p>

    <VideoExample
      client:visible
      src="/Heartbeat.mp4"
      title="Heartbeat monitor"
      credit="@user channel name here"
      creditUrl="https://www.youtube.com/watch?v=bfWD1voJS_w"
    />
    <VideoExample
      client:visible
      src="/LFA.mp4"
      title="Car rev"
      credit="@user channel name here"
      creditUrl="https://www.youtube.com/watch?v=xO-MLcqCwSg"
    />
    <VideoExample
      client:visible
      src="/R7.mp4"
      title="Bike rev"
      credit="@user channel name here"
      creditUrl="https://www.youtube.com/shorts/-3f0GF_R_k8"
    />
  </section>

  <!-- CTA -->
  <div class="cta-strip">
    <a href="/usage" class="btn-accent">View usage docs →</a>
  </div>

  <!-- FOOTER -->
  <footer>
    <p class="footer-by">
      Built by
      <img src="https://github.com/AdityaAnuragi.png?size=32" class="avatar" alt="AdityaAnuragi" />
      AdityaAnuragi
    </p>
    <p class="footer-links">
      v0.0.1 &nbsp;·&nbsp; <a href="#">GitHub</a> &nbsp;·&nbsp; <a href="#">LinkedIn</a>
    </p>
  </footer>

</Layout>

<style>
  /* ── HERO ─────────────────────────────── */
  .hero {
    background: #0f0f0f;
    color: #fff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
  }
  .hero-icons {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }
  .hero-arrow { font-size: 1.25rem; opacity: 0.35; }
  .hero h1 {
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 20px;
    max-width: 640px;
  }
  .hero p {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.5);
    max-width: 400px;
    margin: 0 auto 48px;
    line-height: 1.65;
  }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .btn-ghost {
    text-decoration: none;
    padding: 11px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1.5px solid rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.7);
  }
  .btn-solid {
    text-decoration: none;
    padding: 11px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    background: #7c3aed;
    color: #fff;
  }

  /* ── BANNER ───────────────────────────── */
  .banner {
    background: #fef2f2;
    border-top: 1px solid #fecaca;
    border-bottom: 1px solid #fecaca;
    padding: 28px 24px;
  }
  .banner-inner {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .banner-text { flex: 1; }
  .banner-title { margin: 0 0 4px; font-weight: 700; font-size: 0.95rem; color: #991b1b; }
  .banner-sub { margin: 0; font-size: 0.875rem; color: #b91c1c; }
  .banner-qr { text-align: center; flex-shrink: 0; }
  .qr-box {
    border: 1.5px dashed #fca5a5;
    border-radius: 6px;
    padding: 12px 20px;
    color: #fca5a5;
    font-size: 0.8rem;
  }
  .qr-label { margin: 6px 0 0; font-size: 0.75rem; color: #f87171; }

  /* Hide QR on mobile — they're already on a phone */
  @media (max-width: 540px) {
    .banner-qr { display: none; }
    .banner-inner { justify-content: flex-start; }
  }

  /* ── EXAMPLES ─────────────────────────── */
  .examples {
    max-width: 680px;
    margin: 0 auto;
    padding: 72px 24px;
  }
  .examples h2 { margin: 0 0 8px; font-size: 1.75rem; font-weight: 800; }
  .examples-sub { color: #888; margin: 0 0 40px; line-height: 1.5; }

  /* ── CTA STRIP ────────────────────────── */
  .cta-strip {
    background: #0f0f0f;
    padding: 56px 24px;
    text-align: center;
  }
  .btn-accent {
    text-decoration: none;
    padding: 13px 28px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    background: #7c3aed;
    color: #fff;
    display: inline-block;
  }

  /* ── FOOTER ───────────────────────────── */
  footer {
    border-top: 1px solid #eee;
    padding: 48px 24px;
    text-align: center;
    font-size: 0.9rem;
  }
  footer p { margin: 0 0 8px; }
  footer p:last-child { margin: 0; }
  footer a { color: #aaa; text-decoration: none; }
  footer a:hover { color: #111; }
  .footer-by {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #888;
  }
  .avatar { width: 26px; height: 26px; border-radius: 50%; }
  .footer-links { color: #bbb; }
</style>
