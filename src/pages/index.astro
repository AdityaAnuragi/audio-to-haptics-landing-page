---
import Layout from '../layouts/Layout.astro';
import VideoExample from '../components/VideoExample';
import PageHero from '../components/PageHero.astro';
---

<Layout>

  <!-- HERO -->
  <section class="hero">
  <PageHero>
    <div class="hero-icons">
      <!-- Waveform bars -->
      <svg xmlns="http://www.w3.org/2000/svg" width="52" height="32" viewBox="0 0 52 32" aria-hidden="true">
        <rect x="0"  y="14" width="6" height="4"  rx="3" fill="white" opacity="0.4"/>
        <rect x="8"  y="10" width="6" height="12" rx="3" fill="white" opacity="0.6"/>
        <rect x="16" y="3"  width="6" height="26" rx="3" fill="white"/>
        <rect x="24" y="7"  width="6" height="18" rx="3" fill="white" opacity="0.9"/>
        <rect x="32" y="11" width="6" height="10" rx="3" fill="white" opacity="0.6"/>
        <rect x="40" y="14" width="6" height="4"  rx="3" fill="white" opacity="0.4"/>
      </svg>
      <span class="hero-arrow">→</span>
      <!-- Phone with vibration lines -->
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="36" viewBox="-10 -2 48 40" aria-hidden="true" fill="none" stroke="white" stroke-linecap="round">
        <path d="M-6 11 Q-10 18 -6 25" stroke-width="1.5" opacity="0.35"/>
        <path d="M-2 13 Q-5 18 -2 23"  stroke-width="2"   opacity="0.6"/>
        <rect x="2" y="0" width="24" height="36" rx="4" stroke-width="2"/>
        <rect x="5" y="4" width="18" height="26" rx="2" fill="white" opacity="0.12" stroke="none"/>
        <path d="M30 13 Q33 18 30 23"  stroke-width="2"   opacity="0.6"/>
        <path d="M34 11 Q38 18 34 25" stroke-width="1.5" opacity="0.35"/>
      </svg>
    </div>

    <h1>INSERT CATCHY TAGLINE HERE</h1>
    <p class="hero-sub">INSERT HELPFUL EXPLANATION</p>

    <div class="hero-ctas">
      <a href="#examples" class="btn-ghost">See it in action ↓</a>
      <a href="/usage" class="btn-solid">Get started →</a>
    </div>
  </PageHero>
  </section>

  <!-- DESKTOP WARNING BANNER -->
  <div class="banner-wrap" id="banner">
    <div class="banner">
      <div class="banner-inner">
        <div class="banner-text">
          <p class="banner-title">⚠ Vibration only works on Android Chrome.</p>
        </div>
        <div class="banner-qr">
          <div class="qr-box">INSERT QR CODE HERE</div>
          <p class="qr-label">Scan on your Android phone</p>
        </div>
      </div>
    </div>
  </div>
  <script>
    const ua = navigator.userAgent.toLowerCase();
    if ('vibrate' in navigator && ua.includes('android') && ua.includes('chrome')) {
      document.getElementById('banner')!.style.display = 'none';
    }
  </script>

  <!-- EXAMPLES -->
  <section class="examples" id="examples">
    <!-- Group 1: isolated spikes -->
    <PageHero><p class="group-placeholder">INSERT EXPLANATION 1</p></PageHero>

    <VideoExample
      client:visible
      src="/LFA.mp4"
      title="Car rev"
      credit="@user channel name here"
      creditUrl="https://www.youtube.com/watch?v=xO-MLcqCwSg"
      opts={ { intensityFloor: 0.75 } }
    />
    <VideoExample
      client:visible
      src="/HeartBeatNew.mp4"
      title="Heartbeat monitor"
      credit="@user channel name here"
      creditUrl="https://www.youtube.com/watch?v=bfWD1voJS_w"
      opts={{ sustainUpperBound: 1.1, shortChainBuckets: 6 }}
    />

    <!-- Group 2: sustained sound / PWM -->
    <PageHero><p class="group-placeholder">INSERT EXPLANATION 2</p></PageHero>

    <VideoExample
      client:visible
      src="AWP_fixed.mp4"
      title="Sniper shot"
      credit="@user channel name here"
      creditUrl=""
      opts={{ sustainLowerBound: 0.5, sustainUpperBound: 1.5 }}
    />
  </section>

  <!-- CTA -->
  <div class="cta-strip">
    <a href="/usage" class="btn-accent">View usage docs →</a>
  </div>

  <!-- FOOTER -->
  <footer>
    <p class="footer-by">
      Built by
      <img src="https://github.com/AdityaAnuragi.png?size=32" class="avatar" alt="AdityaAnuragi" />
      Aditya Anuragi
    </p>
    <p class="footer-links">
      v0.0.1 &nbsp;·&nbsp; <a href="#">GitHub</a> &nbsp;·&nbsp; <a href="#">LinkedIn</a>
    </p>
  </footer>

</Layout>

<style>
  /* ── HERO ─────────────────────────────── */
  .hero {
    background: #0f0f0f;
    color: #fff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
  }
  .hero-icons {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }
  .hero-arrow { font-size: 1.25rem; opacity: 0.35; }
  h1 {
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 20px;
    max-width: 640px;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.5);
    max-width: 400px;
    margin: 0 auto 48px;
    line-height: 1.65;
  }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .btn-ghost {
    text-decoration: none;
    padding: 11px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1.5px solid rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.7);
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.55); color: #fff; }
  .btn-ghost:active { opacity: 0.7; }
  .btn-solid {
    text-decoration: none;
    padding: 11px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    background: #7c3aed;
    color: #fff;
    transition: background 0.15s;
  }
  .btn-solid:hover { background: #6d28d9; }
  .btn-solid:active { background: #5b21b6; }

  /* ── BANNER ───────────────────────────── */
  .banner-wrap {
    max-width: 680px;
    margin: 32px auto 0;
    padding: 0 24px;
  }
  .banner {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 10px;
    padding: 20px 24px;
  }
  .banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .banner-text { flex: 1; }
  .banner-title { margin: 0 0 4px; font-weight: 700; font-size: 0.95rem; color: #991b1b; }
  .banner-sub { margin: 0; font-size: 0.875rem; color: #b91c1c; }
  .banner-qr { text-align: center; flex-shrink: 0; }
  .qr-box {
    border: 1.5px dashed #fca5a5;
    border-radius: 6px;
    padding: 12px 20px;
    color: #fca5a5;
    font-size: 0.8rem;
  }
  .qr-label { margin: 6px 0 0; font-size: 0.75rem; color: #f87171; }

  /* Hide QR on mobile — they're already on a phone */
  @media (max-width: 540px) {
    .banner-qr { display: none; }
    .banner-inner { justify-content: flex-start; }
  }

  /* ── EXAMPLES ─────────────────────────── */
  .examples {
    max-width: 680px;
    margin: 0 auto;
    padding: 72px 24px 48px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .group-placeholder { color: #333; font-size: 0.95rem; margin: 0; }

  /* ── CTA STRIP ────────────────────────── */
  .cta-strip {
    padding: 48px 24px;
    text-align: center;
  }
  .btn-accent {
    text-decoration: none;
    padding: 13px 28px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    background: rgba(255,255,255,0.40);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.6);
    color: #111;
    display: inline-block;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-accent:hover { background: rgba(255,255,255,0.55); border-color: rgba(255,255,255,0.8); }
  .btn-accent:active { background: rgba(255,255,255,0.3); }

  /* ── FOOTER ───────────────────────────── */
  footer {
    border-top: 1px solid #eee;
    padding: 32px 24px;
    text-align: center;
    font-size: 0.9rem;
  }
  footer p { margin: 0 0 8px; }
  footer p:last-child { margin: 0; }
  footer a { color: #555; text-decoration: none; }
  footer a:hover { color: #111; }
  .footer-by {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #444;
  }
  .avatar { width: 26px; height: 26px; border-radius: 50%; }
  .footer-links { color: #555; }
</style>
