---
import Layout from '../layouts/Layout.astro';
import VideoExample from '../components/VideoExample';
---

<Layout>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-icons">
      <!-- Waveform -->
      <svg xmlns="http://www.w3.org/2000/svg" width="52" height="32" viewBox="0 0 52 32" aria-hidden="true">
        <rect x="0"  y="14" width="6" height="4"  rx="3" fill="white" opacity="0.4"/>
        <rect x="8"  y="10" width="6" height="12" rx="3" fill="white" opacity="0.6"/>
        <rect x="16" y="3"  width="6" height="26" rx="3" fill="white"/>
        <rect x="24" y="7"  width="6" height="18" rx="3" fill="white" opacity="0.9"/>
        <rect x="32" y="11" width="6" height="10" rx="3" fill="white" opacity="0.6"/>
        <rect x="40" y="14" width="6" height="4"  rx="3" fill="white" opacity="0.4"/>
      </svg>

      <span class="hero-arrow">→</span>

      <!-- Phone with vibration lines -->
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="36" viewBox="-10 -2 48 40" aria-hidden="true" fill="none" stroke="white" stroke-linecap="round">
        <path d="M-6 11 Q-10 18 -6 25" stroke-width="1.5" opacity="0.35"/>
        <path d="M-2 13 Q-5 18 -2 23"  stroke-width="2"   opacity="0.6"/>
        <rect x="2" y="0" width="24" height="36" rx="4" stroke-width="2"/>
        <rect x="5" y="4" width="18" height="26" rx="2" fill="white" opacity="0.12" stroke="none"/>
        <path d="M30 13 Q33 18 30 23"  stroke-width="2"   opacity="0.6"/>
        <path d="M34 11 Q38 18 34 25" stroke-width="1.5" opacity="0.35"/>
      </svg>
    </div>

    <h1>INSERT CATCHY TAGLINE HERE</h1>
    <p>Sync vibration to any audio or video on Android Chrome — no native app required.</p>

    <div class="hero-ctas">
      <a href="#examples" class="btn-ghost">See it in action ↓</a>
      <a href="/usage" class="btn-solid">Get started →</a>
    </div>
  </section>

  <!-- DESKTOP WARNING BANNER -->
  <div class="banner">
    <p><strong>⚠ Vibration only works on Android Chrome.</strong></p>
    <p class="banner-sub">Not supported on iOS, desktop Chrome, Firefox, or any other browser.</p>
    <div class="qr-box">INSERT QR CODE HERE</div>
    <p class="banner-scan">Scan to open on your Android phone.</p>
  </div>

  <!-- EXAMPLES -->
  <section class="examples" id="examples">
    <h2>Hear it. Feel it.</h2>
    <p class="examples-sub">Play on Android Chrome and feel your phone vibrate in sync with the audio.</p>

    <VideoExample
      client:visible
      src="/Heartbeat.mp4"
      title="Heartbeat"
      credit="@user channel name here"
      creditUrl="https://www.youtube.com/watch?v=bfWD1voJS_w"
    />
    <VideoExample
      client:visible
      src="/LFA.mp4"
      title="Lexus LFA"
      credit="@user channel name here"
      creditUrl="https://www.youtube.com/watch?v=xO-MLcqCwSg"
    />
    <VideoExample
      client:visible
      src="/R7.mp4"
      title="Yamaha R7"
      credit="@user channel name here"
      creditUrl="https://www.youtube.com/shorts/-3f0GF_R_k8"
    />
  </section>

  <!-- GET STARTED -->
  <div class="getstarted">
    <pre class="install"><code>npm install audio-to-haptics</code></pre>
    <a href="/usage" class="btn-solid-dark">View usage docs →</a>
  </div>

  <!-- FOOTER -->
  <footer>
    <p class="footer-by">
      Built by
      <img src="https://github.com/AdityaAnuragi.png?size=32" class="avatar" alt="AdityaAnuragi" />
      AdityaAnuragi
    </p>
    <p class="footer-links">
      v0.0.1
      &nbsp;·&nbsp;
      <a href="#">GitHub</a>
      &nbsp;·&nbsp;
      <a href="#">LinkedIn</a>
    </p>
  </footer>

</Layout>

<style>
  /* ── HERO ─────────────────────────────── */
  .hero {
    background: #0f0f0f;
    color: #fff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
  }
  .hero-icons {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }
  .hero-arrow {
    font-size: 1.25rem;
    opacity: 0.4;
    color: #fff;
  }
  .hero h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 20px;
    max-width: 680px;
  }
  .hero p {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.55);
    max-width: 460px;
    margin: 0 auto 48px;
    line-height: 1.6;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn-ghost {
    text-decoration: none;
    padding: 11px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    border: 1.5px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.8);
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.7); color: #fff; }
  .btn-solid {
    text-decoration: none;
    padding: 11px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    background: #fff;
    color: #111;
  }
  .btn-solid:hover { background: #e8e8e8; }

  /* ── BANNER ───────────────────────────── */
  .banner {
    background: #fffbeb;
    border-top: 1px solid #f0c000;
    border-bottom: 1px solid #f0c000;
    padding: 36px 24px;
    text-align: center;
  }
  .banner p { margin: 0; }
  .banner-sub { color: #777; font-size: 0.95rem; margin-top: 6px !important; }
  .qr-box {
    display: inline-block;
    border: 1.5px dashed #ccc;
    border-radius: 6px;
    padding: 20px 36px;
    color: #bbb;
    font-size: 0.85rem;
    margin: 20px 0 10px;
  }
  .banner-scan { color: #aaa; font-size: 0.85rem; }

  /* ── EXAMPLES ─────────────────────────── */
  .examples {
    max-width: 700px;
    margin: 0 auto;
    padding: 80px 24px;
  }
  .examples h2 { margin: 0 0 8px; font-size: 1.75rem; font-weight: 800; }
  .examples-sub { color: #777; margin: 0 0 52px; line-height: 1.5; }

  /* ── GET STARTED ──────────────────────── */
  .getstarted {
    background: #f5f5f5;
    padding: 56px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .install {
    background: #111;
    color: #f8f8f8;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 0.9rem;
    margin: 0;
    display: inline-block;
  }
  .btn-solid-dark {
    text-decoration: none;
    padding: 11px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    background: #111;
    color: #fff;
  }
  .btn-solid-dark:hover { background: #333; }

  /* ── FOOTER ───────────────────────────── */
  footer {
    border-top: 1px solid #eee;
    padding: 48px 24px;
    text-align: center;
    color: #aaa;
    font-size: 0.9rem;
  }
  footer p { margin: 0 0 10px; }
  footer p:last-child { margin: 0; }
  footer a { color: #aaa; text-decoration: none; }
  footer a:hover { color: #111; }
  .footer-by {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #888;
  }
  .avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-block;
  }
  .footer-links { color: #bbb; }
</style>
