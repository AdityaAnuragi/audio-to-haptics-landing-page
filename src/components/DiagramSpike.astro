<div class="diagram">
  <svg viewBox="0 0 560 195" width="100%" aria-hidden="true">

    <!-- Divider -->
    <line x1="281" y1="8" x2="281" y2="155" stroke="#e5e7eb" stroke-width="1.5"/>

    <!-- ===== LEFT PANEL: VIBRATES ===== -->
    <text x="145" y="17" text-anchor="middle" font-size="11" font-weight="700" fill="#16a34a" font-family="system-ui,sans-serif">Vibrates ✓</text>

    <!-- Y-axis + baseline -->
    <line x1="22" y1="37" x2="22" y2="145" stroke="#9ca3af" stroke-width="1.2"/>
    <polygon points="22,32 19.5,39 24.5,39" fill="#9ca3af"/>
    <text x="22" y="29" text-anchor="middle" font-size="8" fill="#9ca3af" font-family="system-ui,sans-serif">amp.</text>
    <line x1="22" y1="145" x2="270" y2="145" stroke="#d1d5db" stroke-width="1"/>

    <!-- Past bars (quiet, avg height = 17px) -->
    <rect x="35"  y="129" width="16" height="16" rx="2" fill="#9ca3af"/>
    <rect x="57"  y="125" width="16" height="20" rx="2" fill="#9ca3af"/>
    <rect x="79"  y="131" width="16" height="14" rx="2" fill="#9ca3af"/>
    <rect x="101" y="127" width="16" height="18" rx="2" fill="#9ca3af"/>

    <!-- Threshold: 1.5 × 17 = 25.5 → y = 145 − 26 = 119 -->
    <line x1="22" y1="119" x2="270" y2="119" stroke="#374151" stroke-width="1.2" stroke-dasharray="5 3"/>
    <text x="262" y="114" text-anchor="end" font-size="8.5" fill="#374151" font-family="system-ui,sans-serif">1.5× past avg (threshold)</text>

    <!-- Current bar — height 62, ratio 62/17 = 3.6 — clears threshold -->
    <rect x="138" y="83" width="20" height="62" rx="2" fill="#7c3aed"/>

    <!-- Sub-labels -->
    <text x="75"  y="157" text-anchor="middle" font-size="9" fill="#666" font-family="system-ui,sans-serif">past</text>
    <text x="148" y="157" text-anchor="middle" font-size="9" fill="#666" font-family="system-ui,sans-serif">current</text>

    <!-- Ratio -->
    <text x="145" y="172" text-anchor="middle" font-size="10" fill="#333" font-family="system-ui,sans-serif">current is 3.6× avg of past → vibrates</text>

    <!-- ===== RIGHT PANEL: SILENT ===== -->
    <text x="420" y="17" text-anchor="middle" font-size="11" font-weight="700" fill="#dc2626" font-family="system-ui,sans-serif">Silent ✗</text>

    <!-- Y-axis + baseline -->
    <line x1="305" y1="37" x2="305" y2="145" stroke="#9ca3af" stroke-width="1.2"/>
    <polygon points="305,32 302.5,39 307.5,39" fill="#9ca3af"/>
    <text x="305" y="29" text-anchor="middle" font-size="8" fill="#9ca3af" font-family="system-ui,sans-serif">amp.</text>
    <line x1="305" y1="145" x2="553" y2="145" stroke="#d1d5db" stroke-width="1"/>

    <!-- Past bars (loud, avg height = 51px) -->
    <rect x="320" y="95"  width="16" height="50" rx="2" fill="#9ca3af"/>
    <rect x="342" y="91"  width="16" height="54" rx="2" fill="#9ca3af"/>
    <rect x="364" y="97"  width="16" height="48" rx="2" fill="#9ca3af"/>
    <rect x="386" y="93"  width="16" height="52" rx="2" fill="#9ca3af"/>

    <!-- Threshold: 1.5 × 51 = 76.5 → y = 145 − 77 = 68 -->
    <line x1="305" y1="68" x2="553" y2="68" stroke="#374151" stroke-width="1.2" stroke-dasharray="5 3"/>
    <text x="545" y="63" text-anchor="end" font-size="8.5" fill="#374151" font-family="system-ui,sans-serif">1.5× past avg (threshold)</text>

    <!-- Current bar — height 57, ratio 57/51 = 1.12 ≈ 1.1 — below threshold (77) -->
    <rect x="420" y="88"  width="20" height="57" rx="2" fill="rgba(124,58,237,0.15)" stroke="#c4b5fd" stroke-width="1.5"/>

    <!-- Sub-labels -->
    <text x="360" y="157" text-anchor="middle" font-size="9" fill="#666" font-family="system-ui,sans-serif">past</text>
    <text x="430" y="157" text-anchor="middle" font-size="9" fill="#666" font-family="system-ui,sans-serif">current</text>

    <!-- Ratio -->
    <text x="420" y="172" text-anchor="middle" font-size="10" fill="#333" font-family="system-ui,sans-serif">current is 1.1× avg of past → stays silent</text>

    <!-- Bottom note -->
    <text x="280" y="190" text-anchor="middle" font-size="9.5" fill="#555" font-family="system-ui,sans-serif">spikeRatio = 1.5 — vibrates when current amplitude exceeds 1.5× avg of past</text>

  </svg>
</div>

