<div class="diagram">
  <svg viewBox="0 0 520 162" width="100%" aria-hidden="true">
    <!-- Divider -->
    <line x1="260" y1="5" x2="260" y2="148" stroke="#e5e7eb" stroke-width="1.5"/>

    <!-- === LEFT PANEL: VIBRATES === -->
    <text x="130" y="15" text-anchor="middle" font-size="11" font-weight="700" fill="#16a34a" font-family="system-ui,sans-serif">Vibrates ✓</text>

    <!-- Past bars (quiet, grey) — avg height ≈ 15px -->
    <rect x="22"  y="98" width="18" height="14" rx="2" fill="#9ca3af"/>
    <rect x="50"  y="94" width="18" height="18" rx="2" fill="#9ca3af"/>
    <rect x="78"  y="100" width="18" height="12" rx="2" fill="#9ca3af"/>
    <rect x="106" y="96" width="18" height="16" rx="2" fill="#9ca3af"/>

    <!-- Threshold line: 1.5 × 15 = 22.5 → y = 112 − 22 = 90 -->
    <line x1="15" y1="90" x2="245" y2="90" stroke="#374151" stroke-width="1.2" stroke-dasharray="5 3"/>
    <text x="242" y="87" text-anchor="end" font-size="9" fill="#374151" font-family="system-ui,sans-serif">threshold</text>

    <!-- Current bar (clears threshold, vibrates) -->
    <rect x="148" y="57" width="22" height="55" rx="2" fill="#7c3aed"/>

    <!-- Sub-labels -->
    <text x="75"  y="126" text-anchor="middle" font-size="9" fill="#666" font-family="system-ui,sans-serif">past</text>
    <text x="159" y="126" text-anchor="middle" font-size="9" fill="#666" font-family="system-ui,sans-serif">current</text>

    <!-- Ratio -->
    <text x="130" y="141" text-anchor="middle" font-size="10" fill="#333" font-family="system-ui,sans-serif">current is 3.6× past avg</text>

    <!-- === RIGHT PANEL: SILENT === -->
    <text x="390" y="15" text-anchor="middle" font-size="11" font-weight="700" fill="#dc2626" font-family="system-ui,sans-serif">Silent ✗</text>

    <!-- Past bars (loud, grey) — avg height ≈ 43px -->
    <rect x="275" y="70" width="18" height="42" rx="2" fill="#9ca3af"/>
    <rect x="300" y="68" width="18" height="44" rx="2" fill="#9ca3af"/>
    <rect x="325" y="72" width="18" height="40" rx="2" fill="#9ca3af"/>
    <rect x="350" y="67" width="18" height="45" rx="2" fill="#9ca3af"/>

    <!-- Threshold line: 1.5 × 43 = 64.5 → y = 112 − 64 = 48 -->
    <line x1="265" y1="48" x2="512" y2="48" stroke="#374151" stroke-width="1.2" stroke-dasharray="5 3"/>
    <text x="510" y="45" text-anchor="end" font-size="9" fill="#374151" font-family="system-ui,sans-serif">threshold</text>

    <!-- Current bar (doesn't reach threshold, silent) -->
    <rect x="388" y="64" width="22" height="48" rx="2" fill="rgba(124,58,237,0.15)" stroke="#c4b5fd" stroke-width="1.5"/>

    <!-- Sub-labels -->
    <text x="322" y="126" text-anchor="middle" font-size="9" fill="#666" font-family="system-ui,sans-serif">past</text>
    <text x="399" y="126" text-anchor="middle" font-size="9" fill="#666" font-family="system-ui,sans-serif">current</text>

    <!-- Ratio -->
    <text x="390" y="141" text-anchor="middle" font-size="10" fill="#333" font-family="system-ui,sans-serif">current is 1.1× past avg</text>

    <!-- Bottom note -->
    <text x="260" y="158" text-anchor="middle" font-size="9.5" fill="#555" font-family="system-ui,sans-serif">spikeRatio = 1.5 — vibration fires when current &gt; 1.5× past avg</text>
  </svg>
</div>

