---
// Renders a full-viewport dark hero section.
// Slot content fades + slides up in sequence on load.
---

<section class="hero">
  <slot />
</section>

<style>
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero {
    background: #0f0f0f;
    color: #fff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
  }

  /* Stagger each direct child */
  .hero > :global(*) {
    animation: hero-in 0.6s ease-out both;
  }
  .hero > :global(*:nth-child(1)) { animation-delay: 0ms; }
  .hero > :global(*:nth-child(2)) { animation-delay: 150ms; }
  .hero > :global(*:nth-child(3)) { animation-delay: 300ms; }
  .hero > :global(*:nth-child(4)) { animation-delay: 450ms; }
</style>
