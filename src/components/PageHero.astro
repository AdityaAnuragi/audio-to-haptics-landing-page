---
// Generic stagger fade-in wrapper.
// Children animate in sequentially when the wrapper enters the viewport.
// Fires once — observer disconnects after first intersection.
---

<div class="fade-group" style="opacity: 0">
  <slot />
</div>

<script>
  document.querySelectorAll<HTMLElement>('.fade-group').forEach(group => {
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        group.style.removeProperty('opacity');
        group.classList.add('visible');
        observer.disconnect();
      }
    }, { threshold: 0.1 });
    observer.observe(group);
  });
</script>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .fade-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* Hidden until intersection fires */
  .fade-group > :global(*) {
    opacity: 0;
    transform: translateY(14px);
  }

  /* Full animation shorthand per child — delay baked in to avoid cascade conflicts */
  .fade-group.visible > :global(*:nth-child(1)) { animation: fade-in-up 0.6s ease-out 0ms   both; }
  .fade-group.visible > :global(*:nth-child(2)) { animation: fade-in-up 0.6s ease-out 150ms both; }
  .fade-group.visible > :global(*:nth-child(3)) { animation: fade-in-up 0.6s ease-out 300ms both; }
  .fade-group.visible > :global(*:nth-child(4)) { animation: fade-in-up 0.6s ease-out 450ms both; }
</style>
